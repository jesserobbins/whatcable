<script>
  // Replace the hardcoded star count with the live figure from GitHub.
  // Falls back silently to the "5.3k" already in the markup if the call
  // fails or the visitor is rate-limited (GitHub allows 60/hour per IP).
  fetch("https://api.github.com/repos/darrylmorley/whatcable")
    .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
    .then(function (data) {
      var n = data.stargazers_count;
      if (typeof n !== "number") return;
      var label = n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, "") + "k" : String(n);
      document.querySelectorAll("[data-gh-stars]").forEach(function (el) {
        el.textContent = label;
      });
    })
    .catch(function () {});
</script>
